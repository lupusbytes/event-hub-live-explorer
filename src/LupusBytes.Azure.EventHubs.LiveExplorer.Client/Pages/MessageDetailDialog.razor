<MudDialog>
    <DialogContent>
        @if (HasMetadata)
        {
            <MudText Typo="Typo.subtitle2" Class="mb-2">Metadata</MudText>
            <MudSimpleTable Dense="true" Hover="true" Class="mb-4">
                <tbody>
                    @if (EventHubMessage.MessageId is not null)
                    {
                        <tr><td><strong>Message ID</strong></td><td>@EventHubMessage.MessageId</td></tr>
                    }
                    @if (EventHubMessage.CorrelationId is not null)
                    {
                        <tr><td><strong>Correlation ID</strong></td><td>@EventHubMessage.CorrelationId</td></tr>
                    }
                    @if (EventHubMessage.ContentType is not null)
                    {
                        <tr><td><strong>Content Type</strong></td><td>@EventHubMessage.ContentType</td></tr>
                    }
                    @if (EventHubMessage.Properties is { Count: > 0 })
                    {
                        @foreach (var prop in EventHubMessage.Properties)
                        {
                            <tr><td><strong>@prop.Key</strong></td><td>@prop.Value</td></tr>
                        }
                    }
                </tbody>
            </MudSimpleTable>
        }
        <MudText Typo="Typo.subtitle2" Class="mb-2">Body</MudText>
        <MudPaper Class="pa-4" Style="max-height: 60vh; overflow: auto;" Outlined="true">
            <pre class="json-viewer" style="white-space: pre-wrap; word-break: break-word; margin: 0;">@HighlightedMessage</pre>
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CopyFormattedAsync" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ContentCopy">Copy</MudButton>
        <MudButton OnClick="Cancel">Close</MudButton>
    </DialogActions>
</MudDialog>