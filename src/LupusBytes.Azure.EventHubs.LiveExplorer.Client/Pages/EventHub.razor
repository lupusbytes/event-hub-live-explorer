@page "/event-hubs/{serviceKey}"
@using LupusBytes.Azure.EventHubs.LiveExplorer.Contracts

<PageTitle>@ServiceKey</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@ServiceKey</MudText>

<MudForm @bind-IsValid="@isValidInput">
    <MudTextField Immediate="true" T="string" Label="Event Hub message" @bind-Value="input" Required="true" RequiredError="A message is required!" Variant="Variant.Outlined" Placeholder="Enter your message..." Lines="3" />
</MudForm>
<MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!isValidInput)" OnClick="@(() => SubmitAsync())">Submit</MudButton>
<MudButton Variant="Variant.Outlined" Color="Color.Secondary" Disabled="@(!IsInputValidJson)" OnClick="@FormatInput" StartIcon="@Icons.Material.Filled.AutoFixHigh">Format JSON</MudButton>
@if (!string.IsNullOrWhiteSpace(input))
{
    <MudChip T="string" Color="@(IsInputValidJson ? Color.Success : Color.Default)" Size="Size.Small" Style="pointer-events: none;">
        @(IsInputValidJson ? "Valid JSON" : "Plain text")
    </MudChip>
}
<br />
<MudIconButton Icon="@CurrentIcon" Color="Color.Primary" Size="Size.Medium" OnClick="@(() => TogglePlayPause())" />
<MudIconButton Icon="@CustomIcons.Broom" Color="Color.Default" OnClick="@(ClearMessages)" />
<MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Default" OnClick="@ExportJsonAsync" Disabled="@(messages.Count == 0)" title="Export as JSON" />
<MudIconButton Icon="@Icons.Material.Filled.TableChart" Color="Color.Default" OnClick="@ExportCsvAsync" Disabled="@(messages.Count == 0)" title="Export as CSV" />
<MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.Inbox" Style="pointer-events: none;">@messages.Count messages</MudChip>
<MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.Speed" Style="pointer-events: none;">@throughput.ToString("F1") msg/s</MudChip>
<MudIconButton Icon="@Icons.Material.Filled.DonutSmall" Color="@(showChart ? Color.Primary : Color.Default)" Size="Size.Medium" OnClick="@(() => showChart = !showChart)" title="Toggle partition chart" />

@if (showChart && messages.Count > 0)
{
    <MudPaper Class="pa-4 mb-4" Outlined="true">
        <MudText Typo="Typo.subtitle2" Class="mb-2">Messages per Partition</MudText>
        <MudChart ChartType="ChartType.Donut" InputData="@GetPartitionChartData()" InputLabels="@GetPartitionChartLabels()" Width="300px" Height="300px" />
    </MudPaper>
}

@if (messages.Count > 0)
{
    <div style="display: flex; gap: 16px; align-items: center; margin-bottom: 8px;">
        <MudTextField @bind-Value="searchFilter" Immediate="true" Placeholder="Search messages..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined" Margin="Margin.Dense" Style="flex: 1;" />
        <MudSelect T="string" @bind-Value="partitionFilter" Label="Partition" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Style="width: 150px;">
            @foreach (var partitionId in eventHub?.PartitionIds ?? [])
            {
                <MudSelectItem Value="@partitionId">@partitionId</MudSelectItem>
            }
        </MudSelect>
    </div>
    <MudTable Items="@FilteredMessages" Hover="true" SortLabel="Sort By" TableClass="table-fixed-layout">
        <ColGroup>
            <col style="width: 180px;" />
            <col style="width: 120px;" />
            <col style="width: 100px;" />
            <col />
        </ColGroup>
        <HeaderContent>
            <MudTh>
                <MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="new Func<EventHubMessage, object>(x => x.EnqueuedTime)">Enqueued Time</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<EventHubMessage, object>(x => x.SequenceNumber)">Sequence Number</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<EventHubMessage, object>(x => x.PartitionId)">Partition ID</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<EventHubMessage, object>(x => x.Message)">Message</MudTableSortLabel>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Enqueued Time">@context.EnqueuedTime.ToLocalTime().ToString("yyyy-MM-ddTHH:mm:ss.fffzzz")</MudTd>
            <MudTd DataLabel="Sequence Number">@context.SequenceNumber</MudTd>
            <MudTd DataLabel="Partition ID">@context.PartitionId</MudTd>
            <MudTd DataLabel="Message" Style="overflow: hidden;">
                <div style="display: flex; align-items: center; gap: 4px;">
                    <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; flex: 1;">@context.Message</span>
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" Style="flex-shrink: 0;" OnClick="@(() => CopyMessageAsync(context.Message))" title="Copy message" />
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Style="flex-shrink: 0;" OnClick="@(() => ShowMessageDetailAsync(context))" title="View message" />
                </div>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }"/>
        </PagerContent>
    </MudTable>
}